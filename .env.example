# ─── Polymarket ──────────────────────────────────────────────────────────────
# Wallet private key (never commit the real value)
WALLET_PRIVATE_KEY=0x...

# ─── Scanner ─────────────────────────────────────────────────────────────────
# How often the scanner runs (seconds)
SCAN_INTERVAL_SECONDS=120

# Minimum liquidity in USD for a market to be considered
MIN_LIQUIDITY_USD=500

# Minimum edge to flag as an opportunity (0.0 – 1.0)
MIN_EDGE_THRESHOLD=0.08

# ─── Paper Trading ───────────────────────────────────────────────────────────
PAPER_STARTING_BALANCE=1000.0
PAPER_MAX_POSITION_USD=10.0
MAX_OPEN_POSITIONS=5

# ─── Telegram (optional) ─────────────────────────────────────────────────────
# Get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
