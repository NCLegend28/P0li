# ─── Polymarket ──────────────────────────────────────────────────────────────
# Wallet private key (never commit the real value)
WALLET_PRIVATE_KEY=0x...

# ─── Scanner ─────────────────────────────────────────────────────────────────
# How often the scanner runs (seconds)
SCAN_INTERVAL_SECONDS=120

# Minimum liquidity in USD for a market to be considered
MIN_LIQUIDITY_USD=500

# Minimum edge to flag as an opportunity (0.0 – 1.0)
MIN_EDGE_THRESHOLD=0.08

# ─── Paper Trading ───────────────────────────────────────────────────────────
PAPER_STARTING_BALANCE=1000.0
PAPER_MAX_POSITION_USD=10.0
MAX_OPEN_POSITIONS=5

# ─── Telegram (optional) ─────────────────────────────────────────────────────
# Get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Polymarket US (sports bot) ──────────────────────────────────────────────
# Separate credentials from polymarket.us/developer (NOT the same as CLOB keys)
POLYMARKET_KEY_ID=
POLYMARKET_SECRET_KEY=
SPORTS_ENABLED=false
SPORTS_SCAN_INTERVAL_SECONDS=30
SPORTS_MIN_EDGE=0.05
SPORTS_MAX_DAILY_LOSS=50.0

# ─── The Odds API (Layer 2 — sports confirmation) ─────────────────────────────
# Free tier: 500 req/month — https://the-odds-api.com/
ODDS_API_KEY=

# ─── Log paths (override to route logs elsewhere) ────────────────────────────
# Each bot writes to its own file; bot.log catches everything.
LOG_FILE_PATH=data/trades/bot.log
WEATHER_LOG_PATH=data/trades/weather.log
SPORTS_LOG_PATH=data/trades/sports.log

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
